APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Drives Carbon/Eloquent timestamps. Stored times follow this zone, so changing
# it on an existing dataset shifts how past timestamps are interpreted.
APP_TIMEZONE=Europe/Moscow
APP_URL=http://localhost
# First host is the technical domain (admin panel, API, Horizon — derived from
# APP_URL); the rest are short-link domains only and 404 those subsystems.
# Override the split with APP_TECHNICAL_HOST if it must differ from APP_URL.
APP_HOST=localhost

# Dedicated salt for short-code generation (Hashids). Independent of APP_KEY so
# the key can be rotated without breaking existing links. Must stay stable once
# links exist. Generate with: php artisan tinker --execute 'echo bin2hex(random_bytes(16));'
HASHIDS_SALT=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Local dev logs to a single file. In production set LOG_STACK=stderr (the
# containers have no persistent storage volume, so file logs are lost on
# redeploy; stderr is captured by Docker) and LOG_LEVEL=warning (debug is
# verbose and may log sensitive request context).
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=brevity
DB_USERNAME=root
DB_PASSWORD=
# Set to require/verify-full once the database enforces TLS.
# DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
# Set true in production: the app is always served over HTTPS, so the session
# cookie should carry the Secure flag.
# SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Use a real SMTP mailer in any environment that sends mail (e.g. admin password
# resets). With the default `log` mailer those messages are written to the log
# and never delivered. Set MAIL_USERNAME/MAIL_PASSWORD in the environment .env.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Octane runtime. Production runs frankenphp (see docker-compose.production.yml).
OCTANE_SERVER=frankenphp

# Error tracking. Leave empty to disable Sentry (e.g. local dev). Set the real
# DSN in production.
SENTRY_LARAVEL_DSN=
