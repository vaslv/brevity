APP_NAME=Brevity
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Drives Carbon/Eloquent timestamps. Stored times follow this zone, so changing
# it on an existing dataset shifts how past timestamps are interpreted.
APP_TIMEZONE=Europe/Moscow
APP_URL=http://localhost
# First host is the technical domain (admin panel, API, Horizon — derived from
# APP_URL) and resolves no short codes; every other host is a short-link domain
# only and 404s those subsystems. Override the split with APP_TECHNICAL_HOST if
# it must differ from APP_URL.
APP_HOST=localhost

# Reverse-proxy / load-balancer ranges whose X-Forwarded-For is trusted
# (r37). Comma-separated CIDRs, or '*' to trust any proxy. Empty falls back to
# the RFC 1918 ranges. Production MUST narrow this to the real LB subnet — a
# too-wide value lets co-located clients spoof the client IP (forged click IP,
# rate-limit bypass).
TRUSTED_PROXIES=

# Dedicated salt for short-code generation (Hashids). Independent of APP_KEY so
# the key can be rotated without breaking existing links. Must stay stable once
# links exist. Generate with: php artisan tinker --execute 'echo bin2hex(random_bytes(16));'
HASHIDS_SALT=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
# Rolling window (days) for the "coldest" domain-selection strategy.
DOMAIN_COLDEST_PERIOD_DAYS=30

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Production-only: contact email for the nginx acme-companion that issues the
# Let's Encrypt TLS certificates (docker-compose.production.yml). Unused locally.
LETSENCRYPT_EMAIL=

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Local dev logs to a single file. In production set LOG_STACK=stderr (the
# containers have no persistent storage volume, so file logs are lost on
# redeploy; stderr is captured by Docker) and LOG_LEVEL=warning (debug is
# verbose and may log sensitive request context).
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=brevity
DB_USERNAME=root
DB_PASSWORD=
# Set to require/verify-full once the database enforces TLS.
# DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
# Set true in production: the app is always served over HTTPS, so the session
# cookie should carry the Secure flag.
# SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# Queue retry_after: must exceed the longest job timeout (UpdateGeoDatabaseJob
# = 300s) so a still-running geo download is not released and re-reserved.
REDIS_QUEUE_RETRY_AFTER=360

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Use a real SMTP mailer in any environment that sends mail (e.g. admin password
# resets). With the default `log` mailer those messages are written to the log
# and never delivered. Set MAIL_USERNAME/MAIL_PASSWORD in the environment .env.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Octane runtime. Production runs frankenphp (see docker-compose.production.yml).
OCTANE_SERVER=frankenphp

# Error tracking. Leave empty to disable Sentry (e.g. local dev). Set the real
# DSN in production.
SENTRY_LARAVEL_DSN=

# Traffic hygiene. Visits from these sources (comma-separated exact IPs or
# CIDR ranges, IPv4/IPv6) record no click and send no callback. The disable
# param, when named, turns off tracking for a single visit (?<name>) and is
# stripped from forward_query; empty = off.
TRACKING_IGNORED_SOURCES=
TRACKING_DISABLE_PARAM=

# Days to keep raw click IPs before ips:prune detaches and deletes them.
TRACKING_IP_RETENTION_DAYS=90

# Admin delete-confirmation warning threshold: a link with at least this
# many clicks gets an explicit warning in the delete modal.
LINK_DELETE_CONFIRM_THRESHOLD=15

# Click geolocation (stage 4). GEOIP_LICENSE_KEY: MaxMind license key for
# downloading/updating the GeoLite2-City database; empty disables the download
# and the traffic-triggered auto-update (lookups still work against a database
# placed on disk). GEOIP_DATABASE_PATH: override the .mmdb location (empty =
# storage/app/geoip/GeoLite2-City.mmdb). GEOIP_MAX_AGE_DAYS: refresh once the
# database is older than this many days. GEOIP_DOWNLOAD_BACKOFF_MINUTES: after a
# run of failed downloads, wait this many minutes before retrying.
GEOIP_LICENSE_KEY=
GEOIP_DATABASE_PATH=
GEOIP_MAX_AGE_DAYS=30
GEOIP_DOWNLOAD_BACKOFF_MINUTES=360
