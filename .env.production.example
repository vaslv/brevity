# Production environment template for the docker-compose.production.yml stack.
# Copy to the server as `.env` next to the compose file(s) and fill in the
# blanks. See docs/06-deploy.md ("Deploying your own instance") for the full
# walkthrough. Key differences from the local .env.example: queue/cache/session
# run on Redis (Horizon), logs go to stderr, debug is off.

APP_NAME=Brevity
APP_ENV=production
# php artisan key:generate --show   (or any 32-byte base64 secret)
APP_KEY=
APP_DEBUG=false
# Drives Carbon/Eloquent timestamps. Stored times follow this zone, so changing
# it on an existing dataset shifts how past timestamps are interpreted.
APP_TIMEZONE=UTC
# The technical host: serves the admin panel (at /login), API and Horizon.
APP_URL=https://brevity.example.com
# Comma-separated list of EVERY hostname this instance serves: the technical
# host first, then each short-link domain. Feeds VIRTUAL_HOST/LETSENCRYPT_HOST
# of the nginx proxy, and `domains:sync` seeds the Domain dictionary from it on
# every deploy (the technical host is skipped).
APP_HOST=brevity.example.com,lnk1.example.com

# Comma-separated CIDRs whose X-Forwarded-For is trusted. Empty falls back to
# the RFC 1918 ranges, which covers the bundled nginx-proxy on the compose
# bridge network. Narrow it to your real front proxy before relying on IP
# conditions or IP-based tracking filters.
TRUSTED_PROXIES=

# Dedicated salt for short-code generation (Hashids). Independent of APP_KEY so
# the key can be rotated without breaking existing links. IMMUTABLE once links
# exist. Generate with: php -r 'echo bin2hex(random_bytes(16));'
HASHIDS_SALT=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
# Rolling window (days) for the "coldest" domain-selection strategy.
DOMAIN_COLDEST_PERIOD_DAYS=30

APP_MAINTENANCE_DRIVER=file

# Contact email for the acme-companion that issues Let's Encrypt certificates.
LETSENCRYPT_EMAIL=

# Image the stack runs, e.g. registry.example.com/you/brevity:1.0.0. The CI
# pipeline exports it per-deploy instead; set it here for manual deploys.
LARAVEL_IMAGE=

BCRYPT_ROUNDS=12

# Containers have no persistent log storage: log to stderr (captured by
# Docker). debug level is verbose and may log sensitive request context.
LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# PostgreSQL is NOT part of the base compose file. Either point DB_HOST at
# your external/managed database, or add the bundled one with
# docker-compose.db.yml (then DB_HOST=pgsql as below).
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=brevity
DB_USERNAME=brevity
DB_PASSWORD=
# Set to require/verify-full once the database enforces TLS.
# DB_SSLMODE=require

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
# The app is served over HTTPS, so the session cookie carries the Secure flag.
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Horizon consumes the redis queue; do not change the driver without also
# rethinking the horizon service in the compose file.
QUEUE_CONNECTION=redis
# Queue retry_after: must exceed the longest job timeout (UpdateGeoDatabaseJob
# = 300s) so a still-running geo download is not released and re-reserved.
REDIS_QUEUE_RETRY_AFTER=360

CACHE_STORE=redis

# `redis` is the compose service name.
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Use a real SMTP mailer in any environment that sends mail (e.g. admin
# password resets). With the `log` mailer those messages are only logged.
MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=smtp.example.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Octane runtime; the compose file starts octane:frankenphp.
OCTANE_SERVER=frankenphp

# Error tracking. Leave empty to disable Sentry.
SENTRY_LARAVEL_DSN=

# Traffic hygiene. Visits from these sources (comma-separated exact IPs or
# CIDR ranges, IPv4/IPv6) record no click and send no callback. The disable
# param, when named, turns off tracking for a single visit (?<name>) and is
# stripped from forward_query; treat the name as a secret. Empty = off.
TRACKING_IGNORED_SOURCES=
TRACKING_DISABLE_PARAM=

# Days to keep raw click IPs before ips:prune detaches and deletes them.
TRACKING_IP_RETENTION_DAYS=90

# Admin delete-confirmation warning threshold: a link with at least this
# many clicks gets an explicit warning in the delete modal.
LINK_DELETE_CONFIRM_THRESHOLD=15

# Click geolocation. GEOIP_LICENSE_KEY: MaxMind license key for downloading and
# auto-updating the GeoLite2-City database; empty disables geo entirely (clicks
# are recorded without a location). GEOIP_DATABASE_PATH: override the .mmdb
# location (empty = storage/app/geoip/GeoLite2-City.mmdb, backed by the shared
# geoip_data volume). GEOIP_MAX_AGE_DAYS: refresh once the database is older
# than this. GEOIP_DOWNLOAD_BACKOFF_MINUTES: wait after failed downloads.
GEOIP_LICENSE_KEY=
GEOIP_DATABASE_PATH=
GEOIP_MAX_AGE_DAYS=30
GEOIP_DOWNLOAD_BACKOFF_MINUTES=360
